<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_vertical"
    android:background="#0A0A0A">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Phone Speaker Mic"
        android:textSize="32sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#FFFFFF"
        android:textAlignment="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Your PC's Virtual Audio Device"
        android:textSize="14sp"
        android:fontFamily="sans-serif"
        android:textColor="#888888"
        android:textAlignment="center"
        android:layout_marginBottom="48dp"
        android:letterSpacing="0.05"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PC IP ADDRESS"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#555555"
        android:layout_marginBottom="8dp"
        android:letterSpacing="0.1"/>

    <EditText
        android:id="@+id/etServerIp"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:hint="e.g. 192.168.1.100"
        android:textColorHint="#444444"
        android:inputType="textVisiblePassword"
        android:paddingHorizontal="24dp"
        android:background="@drawable/bg_input_premium"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#888888"
        android:textAlignment="center"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="WIFI LINK"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_button_connect"
            android:textColor="#0A0A0A"
            android:stateListAnimator="@null"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnUsbConnect"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:text="USB MODE"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_button_usb"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="DISCONNECT"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:background="@drawable/bg_button_disconnect"
        android:textColor="#FF5252"
        android:stateListAnimator="@null"
        android:layout_marginBottom="48dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_card_premium"
        android:padding="24dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOW IT WORKS"
            android:textSize="10sp"
            android:fontFamily="sans-serif-black"
            android:textColor="#555555"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.15"/>
            
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Run the PC Server (pc_server.py)\n2. Note the IP Address shown\n3. Connect and start streaming"
            android:textSize="13sp"
            android:textColor="#AAAAAA"
            android:lineSpacingExtra="6dp"/>
    </LinearLayout>

</LinearLayout>
